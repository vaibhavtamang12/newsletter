GEMINI_API_KEY=your_gemini_api_key_here
GMAIL_USER=your_gmail@gmail.com
GMAIL_APP_PASSWORD=your_app_password_here

# Groq AI (used for summarization)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
NEWSLETTER_SENDER_NAME=Finance Digest Bot
NEWSLETTER_SENDER_EMAIL=your_gmail@gmail.com

# Supabase (subscriber storage)
# Project Settings -> API in your Supabase dashboard.
# SUPABASE_SERVICE_KEY is the "service_role" secret key - never expose it client-side.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_role_key_here

# Newsletter content
NEWSLETTER_MAX_ARTICLES=8
